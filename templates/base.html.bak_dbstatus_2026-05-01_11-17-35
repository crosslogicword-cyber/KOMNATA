<!doctype html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Komnata</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>
    <header class="topbar">
        <div>
            <h1>Komnata</h1>
            <p>Magazynowanie produktów według sektorów, regałów i własnych układów miejsc</p>
        </div>
        <nav>
            <a href="{{ url_for('dashboard') }}">Panel</a>
            <a href="{{ url_for('storage_map') }}">Regały</a>
            <a href="{{ url_for('search') }}">Wyszukiwarka</a>
            <a href="{{ url_for('settings') }}">Ustawienia</a>
            <a href="{{ url_for('print_view') }}" target="_blank">Wydruk</a>
      <a href="{{ url_for('backup_now') }}">Export danych do Excel</a>
              <a href="{{ url_for('import_excel') }}">Import Excel</a>
    </nav>

    {% if system_status is defined %}
<div style="margin:10px 0 0 0;font-size:13px;color:#d1d5db;display:flex;gap:14px;flex-wrap:wrap;">
  <span>Neon: <strong>{{ 'OK' if system_status.neon_ok else 'BŁĄD' }}</strong></span>
  <span>Excel: <strong>{{ 'OK' if system_status.excel_ok else 'BRAK' }}</strong></span>
  <span>Ostatnia modyfikacja: <strong>{{ system_status.last_modification or '-' }}</strong></span>
  <span>Ostatni export: <strong>{{ system_status.last_export or '-' }}</strong></span>
</div>
{% endif %}

    </header>

    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <section class="flashes">
          {% for category, message in messages %}
            <div class="flash {{ category }}">{{ message }}</div>
          {% endfor %}
        </section>
      {% endif %}
    {% endwith %}

    <main class="container">
        {% block content %}{% endblock %}
    </main>
</body>
</html>
