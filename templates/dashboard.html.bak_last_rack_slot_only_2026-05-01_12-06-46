<script>
document.addEventListener('DOMContentLoaded', function () {
  const productInput = document.querySelector('input[name="product_name"]');
  const rackSelect = document.querySelector('select[name="rack_id"], select[name="rack"]');
  const slotSelect = document.querySelector('select[name="slot_id"], select[name="slot"]');
  const productList = document.getElementById('product-name-list');
  const form = productInput ? productInput.closest('form') : null;

  const KEY_PRODUCT = 'komnata_last_product_name';
  const KEY_RACK = 'komnata_last_rack_id';
  const KEY_SLOT = 'komnata_last_slot_id';

  function getSlotsByRack() {
    if (typeof slotsByRack !== 'undefined') return slotsByRack;
    if (window.slotsByRack) return window.slotsByRack;
    return {};
  }

  function fillSlotsForRack(rackId, selectedSlotId) {
    if (!slotSelect) return;
    const map = getSlotsByRack();
    const slots = map[String(rackId || '')] || [];

    const current = String(selectedSlotId || '');
    slotSelect.innerHTML = '';

    const empty = document.createElement('option');
    empty.value = '';
    empty.textContent = 'Bez miejsca';
    slotSelect.appendChild(empty);

    slots.forEach(slot => {
      const opt = document.createElement('option');
      opt.value = String(slot.id);
      opt.textContent = slot.code;
      if (current && String(slot.id) === current) opt.selected = true;
      slotSelect.appendChild(opt);
    });
  }

  function setOptionByValue(select, value) {
    if (!select || !value) return false;
    const found = Array.from(select.options).find(o => String(o.value) === String(value));
    if (!found) return false;
    select.value = String(value);
    return true;
  }

  // Produkt
  const savedProduct = localStorage.getItem(KEY_PRODUCT);
  if (productInput && productList && savedProduct) {
    productList.innerHTML = '';
    const opt = document.createElement('option');
    opt.value = savedProduct;
    productList.appendChild(opt);
    productInput.placeholder = 'Ostatnio: ' + savedProduct;
  }

  // Regał + miejsce
  const savedRack = localStorage.getItem(KEY_RACK);
  const savedSlot = localStorage.getItem(KEY_SLOT);

  if (rackSelect && savedRack) {
    setOptionByValue(rackSelect, savedRack);
  }

  if (rackSelect && slotSelect) {
    fillSlotsForRack(rackSelect.value, savedSlot);
  }

  if (rackSelect) {
    rackSelect.addEventListener('change', function () {
      if (rackSelect.value) {
        localStorage.setItem(KEY_RACK, rackSelect.value);
      } else {
        localStorage.removeItem(KEY_RACK);
      }
      localStorage.removeItem(KEY_SLOT);
      fillSlotsForRack(rackSelect.value, '');
    });
  }

  if (slotSelect) {
    if (savedSlot) setOptionByValue(slotSelect, savedSlot);
    slotSelect.addEventListener('change', function () {
      if (slotSelect.value) {
        localStorage.setItem(KEY_SLOT, slotSelect.value);
      } else {
        localStorage.removeItem(KEY_SLOT);
      }
    });
  }

  if (form) {
    form.addEventListener('submit', function () {
      if (productInput && productInput.value.trim()) {
        localStorage.setItem(KEY_PRODUCT, productInput.value.trim());
      }
      if (rackSelect && rackSelect.value) {
        localStorage.setItem(KEY_RACK, rackSelect.value);
      }
      if (slotSelect && slotSelect.value) {
        localStorage.setItem(KEY_SLOT, slotSelect.value);
      }
    });
  }
});
</script>
<!-- LAST_MEMORY_END -->








