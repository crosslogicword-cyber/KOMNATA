<!doctype html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <title>Komnata - wydruk</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 24px; color: #111827; }
        h1 { margin-bottom: 8px; }
        .location { margin: 24px 0; page-break-inside: avoid; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border: 1px solid #d1d5db; padding: 8px; text-align: left; }
        th { background: #f3f4f6; }
        .small { font-size: 12px; color: #6b7280; }
        @media print { .no-print { display: none; } }
    </style>
</head>
<body>
    <button class="no-print" onclick="window.print()">Drukuj</button>
    <h1>Komnata — zestawienie lokalizacji</h1>
    <p class="small">Sortowanie: według czasu dodania, od najwcześniejszego do najpóźniejszego.</p>
    {% for location, items in grouped %}
    <div class="location">
        <h2>{{ location[0] }} / {{ location[1] }} / {{ location[2] }}</h2>
        <table>
            <thead>
                <tr>
                    <th>Produkt</th>
                    <th>Ilość</th>
                    <th>Notatki</th>
                    <th>Dodano</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr>
                    <td>{{ item.product_name }}</td>
                    <td>{{ item.quantity or '-' }}</td>
                    <td>{{ item.notes or '-' }}</td>
                    <td>{{ item.created_at }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endfor %}
</body>
</html>
