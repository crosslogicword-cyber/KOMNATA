<script>
document.addEventListener('DOMContentLoaded', function () {
  const rackSelect = document.getElementById('rack-select');
  const slotSelect = document.getElementById('slot-select');
  const filterRack = document.getElementById('filter-rack');
  const filterSlot = document.getElementById('filter-slot');
  const productInput = document.querySelector('input[name="product_name"]');
  const productList = document.getElementById('product-name-live');
  const addForm = rackSelect ? rackSelect.closest('form') : (productInput ? productInput.closest('form') : null);

  const LAST_RACK_KEY = 'komnata_last_rack_id';
  const LAST_SLOT_KEY = 'komnata_last_slot_id';
  const LAST_PRODUCT_KEY = 'komnata_last_product_name';

  const slotsByRack = {{ slots_by_rack | tojson }};

  function fillSlots(selectEl, rackId, selectedSlotId, emptyLabel) {
    if (!selectEl) return;
    const slots = slotsByRack[String(rackId || '')] || [];
    selectEl.innerHTML = '';

    const emptyOpt = document.createElement('option');
    emptyOpt.value = '';
    emptyOpt.textContent = emptyLabel;
    selectEl.appendChild(emptyOpt);

    for (const slot of slots) {
      const opt = document.createElement('option');
      opt.value = String(slot.id);
      opt.textContent = slot.code;
      if (selectedSlotId && String(selectedSlotId) === String(slot.id)) {
        opt.selected = true;
      }
      selectEl.appendChild(opt);
    }
  }

  function setValueIfExists(selectEl, value) {
    if (!selectEl || !value) return false;
    const found = Array.from(selectEl.options).find(o => String(o.value) === String(value));
    if (!found) return false;
    selectEl.value = String(value);
    return true;
  }

  // ===== FORMULARZ DODAWANIA =====
  const savedRack = localStorage.getItem(LAST_RACK_KEY) || '';
  const savedSlot = localStorage.getItem(LAST_SLOT_KEY) || '';
  const savedProduct = localStorage.getItem(LAST_PRODUCT_KEY) || '';

  if (rackSelect && savedRack) {
    setValueIfExists(rackSelect, savedRack);
  }

  if (rackSelect && slotSelect) {
    fillSlots(slotSelect, rackSelect.value, savedSlot, 'Bez miejsca');
  }

  if (rackSelect) {
    rackSelect.addEventListener('change', function () {
      const rackId = rackSelect.value || '';
      if (rackId) localStorage.setItem(LAST_RACK_KEY, rackId);
      else localStorage.removeItem(LAST_RACK_KEY);

      localStorage.removeItem(LAST_SLOT_KEY);
      fillSlots(slotSelect, rackId, '', 'Bez miejsca');
    });
  }

  if (slotSelect) {
    slotSelect.addEventListener('change', function () {
      const slotId = slotSelect.value || '';
      if (slotId) localStorage.setItem(LAST_SLOT_KEY, slotId);
      else localStorage.removeItem(LAST_SLOT_KEY);
    });
  }

  if (addForm) {
    addForm.addEventListener('submit', function () {
      if (productInput && productInput.value.trim()) {
        localStorage.setItem(LAST_PRODUCT_KEY, productInput.value.trim());
      }
      if (rackSelect && rackSelect.value) {
        localStorage.setItem(LAST_RACK_KEY, rackSelect.value);
      }
      if (slotSelect && slotSelect.value) {
        localStorage.setItem(LAST_SLOT_KEY, slotSelect.value);
      }
    });
  }

  // ===== PODPOWIEDZI PRODUKTÓW =====
  async function refreshProductHints() {
    if (!productInput || !productList) return;

    const q = productInput.value.trim();
    productList.innerHTML = '';

    // ostatni produkt jako pierwsza podpowiedź
    if (savedProduct && (!q || savedProduct.toLowerCase().includes(q.toLowerCase()))) {
      const rememberedOpt = document.createElement('option');
      rememberedOpt.value = savedProduct;
      productList.appendChild(rememberedOpt);
    }

    if (!q) return;

    try {
      const res = await fetch('/api/suggestions?q=' + encodeURIComponent(q));
      const data = await res.json();
      const seen = new Set(Array.from(productList.options).map(o => o.value.toLowerCase()));

      for (const item of data) {
        const name = String(item.product_name || '').trim();
        if (!name) continue;
        if (seen.has(name.toLowerCase())) continue;
        seen.add(name.toLowerCase());

        const opt = document.createElement('option');
        opt.value = name;
        productList.appendChild(opt);
      }
    } catch (e) {}
  }

  if (productInput) {
    if (savedProduct && !productInput.value) {
      productInput.placeholder = 'Ostatnio: ' + savedProduct;
    }
    productInput.setAttribute('autocomplete', 'off');
    productInput.addEventListener('input', refreshProductHints);
    productInput.addEventListener('focus', refreshProductHints);
  }

  // ===== FILTR REGAŁ / MIEJSCE =====
  if (filterRack && filterSlot) {
    fillSlots(filterSlot, filterRack.value, "{{ selected_slot_id or '' }}", 'Wszystkie miejsca');
    filterRack.addEventListener('change', function () {
      fillSlots(filterSlot, filterRack.value, '', 'Wszystkie miejsca');
    });
  }
});
</script>

<!-- FINAL_MEMORY_HINTS_START -->
